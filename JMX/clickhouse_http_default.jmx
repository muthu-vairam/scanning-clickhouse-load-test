    <hashTree>
      <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Compute and log avg/p95/p99" enabled="true">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey"></stringProp>
        <stringProp name="script"><![CDATA[
// Read elapsed times from file and compute avg/p95/p99
def outDir = new File(System.getenv('HOME') + '/jmeter-tests')
def f = new File(outDir, 'elapsed_times.csv')
if (!f.exists()) {
  log.warn('METRICS: elapsed_times.csv not found; no samples?')
  return
}
def times = f.readLines().findAll { it?.trim() }.collect { it as long }
if (times.isEmpty()) {
  log.warn('METRICS: no samples collected')
  return
}
def n = times.size()
long sum = 0L
for (t in times) sum += t
def avg = sum / (double)n
def sorted = new java.util.ArrayList<Long>(times)
java.util.Collections.sort(sorted)
int idx95 = Math.max(0, (int)Math.ceil(0.95d * n) - 1)
int idx99 = Math.max(0, (int)Math.ceil(0.99d * n) - 1)
def p95 = sorted.get(idx95)
def p99 = sorted.get(idx99)
log.info(String.format('METRICS summary: count=%d avg=%.2fms p95=%dms p99=%dms', n, avg, p95, p99))
def jf = new File(outDir, 'metrics_summary.json')
def json = String.format('{"count":%d,"avg_ms":%.2f,"p95_ms":%d,"p99_ms":%d}', n, avg, p95, p99)
jf.setText(json, 'UTF-8')
]]></stringProp>
      </JSR223Sampler>
