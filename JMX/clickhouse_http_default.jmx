          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert rows>0 and contains IP meta (lightweight)" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey"></stringProp>
            <stringProp name="script"><![CDATA[
def body = prev.getResponseDataAsString()
assert body, 'Empty response body'
assert body.contains('"meta"'), 'Missing meta section'
def m = (body =~ /\"rows\"\s*:\s*(\d+)/)
assert m.find(), 'rows field missing'
assert (m.group(1) as int) >= 1, 'rows < 1'
]]></stringProp>
          </JSR223Assertion>
