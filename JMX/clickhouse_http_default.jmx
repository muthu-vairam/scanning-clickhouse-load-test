// Append elapsed time (ms) to a file for cross-thread visibility
def outDir = new File(System.getenv('HOME') + '/jmeter-tests')
outDir.mkdirs()
def f = new File(outDir, 'elapsed_times.csv')
f << (prev.getTime() as long).toString() + System.lineSeparator()
]]></stringProp>
