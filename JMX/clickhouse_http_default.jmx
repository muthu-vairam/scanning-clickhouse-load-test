        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Load next batch and build IPS_IN" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey"></stringProp>
            <stringProp name="script"><![CDATA[
// Determine batch size per iteration
int limit = (props.get('BATCH_LIMIT') ? (props.get('BATCH_LIMIT') as int) : (vars.get('BATCH_LIMIT') ? (vars.get('BATCH_LIMIT') as int) : 5))

// Prefer explicit TSV file if provided; else fall back to dir/glob batches
def tsv = props.get('BATCH_FILE') ?: vars.get('BATCH_FILE')
String path = null
List ipsChunk = []

if (tsv) {
  path = tsv
  // Cache parsed TSV IP list across iterations (per-thread via vars)
  def cached = vars.getObject('TSV_LINES')
  List allIps
  if (cached == null) {
    def raw = new File(path).readLines('UTF-8')
    allIps = []
    for (def line : raw) {
      if (!line) continue
      def s = line.toString().trim()
      if (!s) continue
      if (s.toLowerCase().startsWith('ip') || s.contains(',ip') || s.startsWith('ip\t')) continue
      def parts = s.split('\t')
      def val = (parts.length >= 2 ? parts[1] : parts[0]).trim()
      if (!val) continue
      if (val.contains('*') || val.toUpperCase().contains('XX')) continue
      allIps.add(val)
    }
    vars.putObject('TSV_LINES', allIps)
    vars.put('TSV_TOTAL', String.valueOf(allIps.size()))
  } else {
    allIps = (List) cached
  }
  int total = (vars.get('TSV_TOTAL') ?: String.valueOf(((List)vars.getObject('TSV_LINES')).size())) as int
  int offset = (vars.get('TSV_OFFSET') ?: '0') as int
  if (offset >= total) {
    // wrap to start if loops exceed exact batch count
    offset = 0
  }
  int end = Math.min(offset + limit, total)
  ipsChunk = ((List)vars.getObject('TSV_LINES')).subList(offset, end)
  vars.put('TSV_OFFSET', String.valueOf(end))
  log.info('Using TSV source file: ' + path + ' offset=' + offset + ' size=' + ipsChunk.size() + '/' + total)
} else {
  def dir = props.get('BATCH_DIR') ?: vars.get('BATCH_DIR')
  if (!dir) { dir = System.getenv('HOME') + '/jmeter-tests/ip_batches' }
  def glob = props.get('BATCH_GLOB') ?: vars.get('BATCH_GLOB') ?: 'ips_batch_*.csv'
  def list = vars.getObject('BATCH_LIST')
  if (list == null) {
    def d = new File(dir)
    if (!d.exists()) { throw new RuntimeException('BATCH_DIR not found: ' + dir) }
    def regex = ('^' + glob.replace('.', '\\.').replace('*','.*') + '$')
    list = d.listFiles()?.findAll { it.name ==~ regex }?.collect { it.absolutePath }?.sort()
    if (!list || list.isEmpty()) { throw new RuntimeException('No batch files in ' + dir + ' matching ' + glob) }
    vars.putObject('BATCH_LIST', list)
    vars.put('BATCH_SIZE', String.valueOf(list.size()))
  }
  int idx = (vars.get('BATCH_INDEX') ?: '0') as int
  def blist = (List)vars.getObject('BATCH_LIST')
  if (idx >= blist.size()) {
    log.info('All batches consumed (' + blist.size() + '). Restarting at index 0.')
    idx = 0
  }
  path = blist[idx]
  vars.put('BATCH_INDEX', String.valueOf(idx + 1))
  log.info('Using batch file [' + (idx+1) + '/' + blist.size() + ']: ' + path)
  // read up to limit from CSV (skip header if present)
  def lines = new File(path).readLines('UTF-8')
  def body = (lines && lines[0].toLowerCase().contains('ip')) ? lines.subList(1, lines.size()) : lines
  ipsChunk = body.take(limit)
}

// Quote values for IN (...)
def ips = ipsChunk.collect { "'" + it.replace('\\', '\\\\').replace("'", "\\'") + "'" }
vars.put('IPS_IN', ips.join(', '))

// Build full SQL body and store for the sampler and logging
def sql = new StringBuilder()
sql.append('SELECT\n')
sql.append('*\n')
sql.append('FROM default.fraudlogix\n')
sql.append('WHERE IP IN (\n')
sql.append(ips.join(', ')).append('\n')
sql.append(')\n')
sql.append('FORMAT JSON')
vars.put('SQL_BODY', sql.toString())
log.info('Built IPS_IN with ' + ips.size() + ' values from ' + (path ?: '<N/A>') + '; SQL length=' + vars.get('SQL_BODY').length())
]]></stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log SQL" enabled="false">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey"></stringProp>
            <stringProp name="script"><![CDATA[
def code = (prev.getResponseCode() as String) ?: 'n/a'
def sql  = vars.get('SQL_BODY') ?: '<missing SQL_BODY>'
if (code.startsWith('2')) {
  log.info('SQL (' + code + '):\n' + sql)
} else {
  log.warn('SQL (' + code + '):\n' + sql)
}
]]></stringProp>
          </JSR223PostProcessor>
